<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<targets>
		<target name="logfile" xsi:type="File" fileName="${basedir}/logs/latest.txt"
			archiveFileName="${basedir}/logs/archive/log.{#}.txt"
            archiveNumbering="DateAndSequence"
            archiveAboveSize="102400000"
            archiveDateFormat="yyyyMMdd-hhmm"
			layout="${date:s}-[${pad:padding=5:inner=${level:uppercase=true}}]|[${logger}]: ${message}">
		</target>
		
		<target name="logconsole" xsi:type="ColoredConsole" layout="${date:s}-[${pad:padding=5:inner=${level:uppercase=true}}]|[${logger}]: ${message}" >
			<highlight-row condition="level == LogLevel.Trace" foregroundColor="Gray" />
			<highlight-row condition="level == LogLevel.Debug" foregroundColor="White" />
			<highlight-row condition="level == LogLevel.Info" foregroundColor="Green" />
			<highlight-row condition="level == LogLevel.Warn" foregroundColor="Yellow" />
			<highlight-row condition="level == LogLevel.Error" foregroundColor="Red" />
			<highlight-row condition="level == LogLevel.Fatal" foregroundColor="Red" backgroundColor="White" />
		</target>
	</targets>

	<rules>
		<logger name="*" minlevel="Trace" writeTo="logconsole" />
		<logger name="*" minlevel="Trace" writeTo="logfile" />
	</rules>
</nlog>